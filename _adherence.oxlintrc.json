{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "components/marketing/**",
              "ui_kits/app/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Clash Display|Satoshi|Bricolage Grotesque))/i]",
        "message": "Font not provided by the design system. Available: Clash Display, Satoshi, Bricolage Grotesque."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:query|steps|activeStep|autoplay|footer|style|key|ref|className|style|children)$/]",
        "message": "<AgentStatus> doesn't accept that prop. Declared props: query, steps, activeStep, autoplay, footer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gradient|ink|periwinkle)$/]",
        "message": "<Avatar> tone must be one of 'gradient' | 'ink' | 'periwinkle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|iconLeft|iconRight|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, iconLeft, iconRight, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|padding|radius|shadow|interactive|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, padding, radius, shadow, interactive, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:surface|sunken|gradient|ink)$/]",
        "message": "<Card> tone must be one of 'surface' | 'sunken' | 'gradient' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='shadow'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> shadow must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DecisionAlert'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|insight|priority|time|action|onAction|iconRoot|style|key|ref|className|style|children)$/]",
        "message": "<DecisionAlert> doesn't accept that prop. Declared props: title, insight, priority, time, action, onAction, iconRoot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DecisionAlert'] > JSXAttribute[name.name='priority'] > Literal[value!=/^(?:high|medium|low|opportunity)$/]",
        "message": "<DecisionAlert> priority must be one of 'high' | 'medium' | 'low' | 'opportunity'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FaqItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|children|open|defaultOpen|onToggle|style|key|ref|className|style|children)$/]",
        "message": "<FaqItem> doesn't accept that prop. Declared props: question, children, open, defaultOpen, onToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|root|title|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, root, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|iconSize|variant|shape|iconRoot|title|onClick|disabled|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: name, size, iconSize, variant, shape, iconRoot, title, onClick, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|subtle|solid|outline)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'subtle' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle)$/]",
        "message": "<IconButton> shape must be one of 'rounded' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|placeholder|value|onChange|fill|trailing|error|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, type, placeholder, value, onChange, fill, trailing, error, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='fill'] > Literal[value!=/^(?:tint|plain)$/]",
        "message": "<Input> fill must be one of 'tint' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|direction|caption|icon|iconRoot|style|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, delta, direction, caption, icon, iconRoot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<KpiCard> direction must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|height|root|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, tone, height, root, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|height|tone|showTrack|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, height, tone, showTrack, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gradient|plain)$/]",
        "message": "<ProgressBar> tone must be one of 'gradient' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignalCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|statement|trace|tone|style|key|ref|className|style|children)$/]",
        "message": "<SignalCard> doesn't accept that prop. Declared props: label, statement, trace, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Step'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|key|ref|className|style|children)$/]",
        "message": "<Step> doesn't accept that prop. Declared props: title, body."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|label|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
