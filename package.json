{
  "name": "designsystem",
  "private": true,
  "description": "Alfred AI design system — build, verifiers, and type-check tooling",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:types": "node scripts/verify-types.mjs",
    "build": "node scripts/build-bundle.mjs",
    "test": "playwright test --project=interaction",
    "test:visual": "playwright test --project=visual"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
